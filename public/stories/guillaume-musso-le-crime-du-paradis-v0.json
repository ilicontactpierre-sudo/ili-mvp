      ]
    },
    {
      "id": "seg_1781005462920_4_usxd9",
      "lines": [
        "Des remontées acides lui brûlaient l’estomac."
      ],
      "text": "Des remontées acides lui brûlaient l’estomac.",
      "breakAt": null,
