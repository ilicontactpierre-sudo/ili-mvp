    {
      "id": "seg_1781326327990_43_scpyv",
      "lines": [
        "Rob lève les yeux vers elle."
      ],
      "text": "Rob lève les yeux vers elle.",
      "breakAt": null,
      "isLeader": false,
      "audioEvents": []
    },
    {
      "id": "seg_1781326327990_44_uyg8t",
      "lines": [
        "Pas besoin de parler, elle sait qu’elle rentre seule."
      ],
      "text": "Pas besoin de parler, elle sait qu’elle rentre seule. Elle serre son poignet nu aussi fort que se serre son cœur à cet instant. Ils avaient peut-être raison les collègues, on ne sort pas indemne de ce genre de carrière… Et ce que Rob ne dit pas, c’est qu’il le sait et qu’il en a peur.",
      "breakAt": 220,
      "isLeader": false,
      "audioEvents": [],
      "delay": 4800
