    {
      "id": "seg_1781326327990_3_kn93q",
      "lines": [
        "Rob continue sur sa lancée : « Un discours, un discours, un discours ! »."
      ],
      "text": "Rob continue sur sa lancée : </couleur:#d4a96a|« Un discours, un discours, un discours ! »./>",
      "breakAt": null,
